rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function roleOf(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && roleOf(request.auth.uid) == 'admin';
    }

    match /users/{uid} {
      // A user can read their own profile; admins can read any.
      allow read: if isSelf(uid) || isAdmin();

      // On signup a user may create only their own doc, and only as 'client'.
      // This blocks self-elevation to trainer/admin at registration.
      allow create: if isSelf(uid) && request.resource.data.role == 'client';

      // Users may edit their own profile but must NOT change their role.
      // Admins may change anything (e.g. grant the trainer role).
      allow update: if isAdmin()
        || (isSelf(uid) && request.resource.data.role == resource.data.role);

      allow delete: if isSelf(uid) || isAdmin();
    }

    // Everything else is denied until its own milestone adds explicit rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
