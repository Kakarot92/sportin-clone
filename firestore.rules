rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function roleOf(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && roleOf(request.auth.uid) == 'admin';
    }

    match /users/{uid} {
      // A user can read their own profile; admins can read any.
      allow read: if isSelf(uid) || isAdmin();

      // On signup a user may create only their own doc, and only as 'client'.
      // This blocks self-elevation to trainer/admin at registration.
      allow create: if isSelf(uid) && request.resource.data.role == 'client';

      // Users may edit their own profile but must NOT change their role.
      // Admins may change anything (e.g. grant the trainer role).
      allow update: if isAdmin()
        || (isSelf(uid) && request.resource.data.role == resource.data.role);

      allow delete: if isSelf(uid) || isAdmin();
    }

    // Public trainer profiles: any signed-in user can browse them (to choose a
    // trainer); only an admin or the trainer themselves may write.
    match /trainers/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSelf(uid) && roleOf(uid) == 'trainer');
    }

    // ── M4: Schedules & availability ────────────────────────────────────────

    // Weekly availability templates: one document per trainer.
    // Any signed-in user may read (clients need to see trainer slots).
    // Only the trainer themselves or an admin may write.
    match /availabilityTemplates/{trainerUid} {
      allow read: if isSignedIn();
      allow write: if isAdmin()
        || (isSelf(trainerUid) && roleOf(trainerUid) == 'trainer');
    }

    // One-off availability exceptions (per trainer, per date).
    match /availabilityExceptions/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isSignedIn()
            && request.resource.data.trainerUid == request.auth.uid
            && roleOf(request.auth.uid) == 'trainer');
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.trainerUid == request.auth.uid);
    }

    // Studio-wide settings (opening hours, closed days).
    // Any signed-in user may read; only admins may write.
    match /studioSettings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Bookings: any signed-in user may read.
    // M5: create/update/delete rules for booking creation and cancellation.
    match /bookings/{id} {
      allow read: if isSignedIn();
      // A client creates their own booking (status must start as 'booked').
      allow create: if isSignedIn()
        && request.resource.data.clientUid == request.auth.uid
        && request.resource.data.status == 'booked';
      // Update: the booking's client (e.g. rebooking a freed slot / future cancel),
      // the trainer for that booking, or an admin.
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.clientUid == request.auth.uid)
        || (isSignedIn() && resource.data.trainerUid == request.auth.uid)
        || (isSignedIn() && resource.data.status == 'cancelled'
            && request.resource.data.clientUid == request.auth.uid
            && request.resource.data.status == 'booked');
      allow delete: if isAdmin();
    }

    // ── M8: Packages / memberships ──────────────────────────────────────────

    // M8: package/membership types (admin-defined).
    match /packageTypes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // M8: a client's assigned package instances. Admins assign; any of the
    // studio's trainers may adjust (credit refund on cancel can be triggered
    // by a trainer cancelling a client's session) or the client's own booking
    // flow decrements/increments their own package during transactions.
    match /clientPackages/{id} {
      allow read: if isSignedIn()
        && (isSelf(resource.data.clientUid) || isAdmin()
            || roleOf(request.auth.uid) == 'trainer');
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.clientUid == request.auth.uid)
        || (isSignedIn() && roleOf(request.auth.uid) == 'trainer');
      allow delete: if isAdmin();
    }

    // ── M7: Group classes ───────────────────────────────────────────────────
    //
    // Trainers create/manage their own classes; any signed-in user may read
    // and join/leave (joining updates `joinedCount`, a field on a doc the
    // trainer owns — scoped narrowly via affectedKeys() so a client can ONLY
    // ever touch that one field, never rewrite the class).
    match /groupClasses/{classId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && roleOf(request.auth.uid) == 'trainer'
        && request.resource.data.trainerUid == request.auth.uid;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.trainerUid == request.auth.uid)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedCount']));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.trainerUid == request.auth.uid);

      match /participants/{clientUid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == clientUid;
        allow delete: if isSignedIn() && request.auth.uid == clientUid;
        allow update: if false;
      }
    }

    // ── M12: Measurements ───────────────────────────────────────────────────

    // M12: body-measurement entries. Client owns their own entries; their
    // trainer(s) — determined via the trainerClients marker below — may read
    // but never write (AS-057, AS-062, AS-063, AS-064).
    match /measurements/{id} {
      allow read: if isSignedIn()
        && (isSelf(resource.data.clientUid)
            || isAdmin()
            || (roleOf(request.auth.uid) == 'trainer'
                && exists(/databases/$(database)/documents/trainerClients/$(request.auth.uid + '_' + resource.data.clientUid))));
      allow create: if isSignedIn() && request.resource.data.clientUid == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.clientUid == request.auth.uid);
    }

    // M12: trainer-client relationship marker, upserted when a client books a
    // trainer. Lets security rules answer "is this trainer's client" without a
    // collection query (rules can only exists()/get() a known doc path).
    match /trainerClients/{id} {
      allow read: if isSignedIn()
        && (isSelf(resource.data.trainerUid) || isSelf(resource.data.clientUid) || isAdmin());
      allow create, update: if isSignedIn() && request.resource.data.clientUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── M11: Chat ───────────────────────────────────────────────────────────

    // M11: 1-on-1 chat between a client and a trainer. Thread ID is
    // deterministic ("{trainerUid}_{clientUid}"), matching the same convention
    // used for bookings and the trainerClients marker elsewhere in this app.
    match /chats/{threadId} {
      allow read: if isSignedIn()
        && (isSelf(resource.data.trainerUid) || isSelf(resource.data.clientUid) || isAdmin());
      allow create, update: if isSignedIn()
        && (request.resource.data.trainerUid == request.auth.uid
            || request.resource.data.clientUid == request.auth.uid);

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(threadId)).data.trainerUid == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(threadId)).data.clientUid == request.auth.uid
              || isAdmin());
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (get(/databases/$(database)/documents/chats/$(threadId)).data.trainerUid == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(threadId)).data.clientUid == request.auth.uid);
      }
    }

    // M11: group class chat, visible only to that class's trainer and its
    // joined participants (reuses the groupClasses/{classId}/participants
    // subcollection from M7 — no separate participant list to maintain).
    match /groupClassChats/{classId} {
      allow read: if isSignedIn()
        && (get(/databases/$(database)/documents/groupClasses/$(classId)).data.trainerUid == request.auth.uid
            || exists(/databases/$(database)/documents/groupClasses/$(classId)/participants/$(request.auth.uid))
            || isAdmin());
      allow create, update: if isSignedIn();

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/groupClasses/$(classId)).data.trainerUid == request.auth.uid
              || exists(/databases/$(database)/documents/groupClasses/$(classId)/participants/$(request.auth.uid))
              || isAdmin());
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (get(/databases/$(database)/documents/groupClasses/$(classId)).data.trainerUid == request.auth.uid
              || exists(/databases/$(database)/documents/groupClasses/$(classId)/participants/$(request.auth.uid)));
      }
    }

    // Everything else is denied until its own milestone adds explicit rules.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
